<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    Library view. Layout regions:
      top    = app bar (title + search + actions) and a secondary toolbar
      left   = shelves sidebar
      center = scrollable book grid (filled at runtime by LibraryController)
      bottom = status bar
    Everything marked "wire up later" has a stub handler in LibraryController
    so the FXML loads cleanly today.
-->

<BorderPane prefHeight="680" prefWidth="1024" styleClass="library-root" stylesheets="@../styles/library.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ymt.ui.controller.LibraryController">

    <!-- Shared toggle groups: grid/list view switch and light/dark theme switch. -->
    <fx:define>
        <ToggleGroup fx:id="viewToggle" />
        <ToggleGroup fx:id="themeGroup" />
    </fx:define>

    <!-- ============ TOP ============ -->
    <top>
        <VBox styleClass="top-bar">
            <!-- App bar: title left, search + primary actions right -->
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="app-bar">
                <padding>
                    <Insets bottom="14.0" left="18.0" right="18.0" top="14.0" />
                </padding>

                <Label styleClass="app-title" text="My Library" />

                <Region HBox.hgrow="ALWAYS" />

                <TextField fx:id="searchField" onAction="#onSearch" prefWidth="260.0" promptText="Search title or author…" styleClass="search-field" />
                <Button onAction="#onSearch" styleClass="ghost-button" text="Search" />
                <Button fx:id="addBookButton" onAction="#onAddBook" styleClass="primary-button" text="+ Add book" />
            </HBox>

            <Separator />

            <!-- Secondary toolbar: sort / filter / view switch (wire up later) -->
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="toolbar">
                <padding>
                    <Insets bottom="8.0" left="18.0" right="18.0" top="8.0" />
                </padding>

                <Label styleClass="toolbar-label" text="Sort:" />
                <ComboBox fx:id="sortCombo" onAction="#onSortChanged" prefWidth="160.0" />

                <Label styleClass="toolbar-label" text="Shelf:" />
                <ComboBox fx:id="filterCombo" onAction="#onFilterChanged" prefWidth="160.0" />

                <Region HBox.hgrow="ALWAYS" />

                <ToggleButton onAction="#onToggleView" selected="true" styleClass="view-toggle" text="Grid">
               <toggleGroup>
                  <ToggleGroup fx:id="viewToggle" />
               </toggleGroup></ToggleButton>
                <ToggleButton onAction="#onToggleView" styleClass="view-toggle" text="List" toggleGroup="$viewToggle" />

                <Separator orientation="VERTICAL" />

                <!-- Light / dark theme switch -->
                <ToggleButton fx:id="lightThemeToggle" onAction="#onSelectTheme" styleClass="view-toggle" text="☀ Light">
               <toggleGroup>
                  <ToggleGroup fx:id="themeGroup" />
               </toggleGroup></ToggleButton>
                <ToggleButton fx:id="darkThemeToggle" onAction="#onSelectTheme" selected="true" styleClass="view-toggle" text="☾ Dark" toggleGroup="$themeGroup" />
            </HBox>
        </VBox>
    </top>

    <!-- ============ LEFT: shelves (wire up later) ============ -->
    <left>
        <VBox spacing="6.0" styleClass="sidebar">
            <padding>
                <Insets bottom="16.0" left="16.0" right="12.0" top="16.0" />
            </padding>

            <Label styleClass="sidebar-heading" text="SHELVES" />

            <Button maxWidth="Infinity" onAction="#onSelectShelf" styleClass="shelf-button" text="All books" />
            <Button maxWidth="Infinity" onAction="#onSelectShelf" styleClass="shelf-button" text="Currently reading" />
            <Button maxWidth="Infinity" onAction="#onSelectShelf" styleClass="shelf-button" text="Favorites" />
            <Button maxWidth="Infinity" onAction="#onSelectShelf" styleClass="shelf-button" text="Finished" />

            <Region VBox.vgrow="ALWAYS" />

            <Button maxWidth="Infinity" onAction="#onAddShelf" styleClass="ghost-button" text="+ New shelf" />
        </VBox>
    </left>

    <!-- ============ CENTER: book grid ============ -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="library-scroll">
            <content>
                <FlowPane fx:id="bookContainer" hgap="22.0" styleClass="book-grid" vgap="26.0">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </FlowPane>
            </content>
        </ScrollPane>
    </center>

    <!-- ============ BOTTOM: status bar ============ -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="status-bar">
            <padding>
                <Insets bottom="8.0" left="18.0" right="18.0" top="8.0" />
            </padding>
            <Label fx:id="bookCountLabel" styleClass="status-text" text="0 books" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#onRefresh" styleClass="ghost-button" text="Refresh" />
        </HBox>
    </bottom>
</BorderPane>
